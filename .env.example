DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Auto-approval configuration
# Enable automatic approval for agent API requests to internal endpoints (default: true)
# PAPERCLIP_AUTO_APPROVE_INTERNAL_API=true

# Comma-separated list of additional URLs to auto-approve (in addition to PAPERCLIP_API_URL and localhost)
# PAPERCLIP_AUTO_APPROVE_URL_WHITELIST=https://internal.api.example.com,https://services.internal.local
